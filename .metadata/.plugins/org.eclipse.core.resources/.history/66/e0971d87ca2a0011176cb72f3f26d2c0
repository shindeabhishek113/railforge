server:
  port: 8080

spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      mvc:
        routes:
          - id: train-service
            uri: http://localhost:8081
            predicates:
              - Path=/api/trains/**, /api/stations/**, /api/schedules/**

          - id: booking-service
            uri: http://localhost:8082
            predicates:
              - Path=/api/bookings/**, /api/auth/**

          - id: notification-service
            uri: http://localhost:8083
            predicates:
              - Path=/api/notifications/**

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: always

logging:
  level:
    com.railforge: DEBUG
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n"